{
  "expo": {
    "name": "lifeOS",
    "slug": "lifeos",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.personal.lifeos"
    },
    "android": {
      "package": "com.personal.lifeos",
      "adaptiveIcon": {
        "backgroundColor": "#3a3f32"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3a3f32",
          "resizeMode": "contain"
        }
      ]
    ],
    "scheme": "lifeos",
    "experiments": {
      "typedRoutes": true
    }
  }
}
